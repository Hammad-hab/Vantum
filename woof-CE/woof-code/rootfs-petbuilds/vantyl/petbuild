download() {
    [ -e Vantyl.tar.gz ] || curl -L https://github.com/Hammad-hab/Vantyl/archive/refs/heads/main.tar.gz -o Vantyl.tar.gz
}


build() {
    [ -d Vantyl-main ] || tar -xzf Vantyl.tar.gz
    cd Vantyl-main
    rm -rf examples
    rm -rf assets
    rm -f README.md
    rm -f .gitattributes

    {
        echo "#!/usr/bin/env python3"
        cat vantyl.py
    } > vantyl.py.new && mv vantyl.py.new vantyl
    install -D -m 755 vantyl /usr/sbin/vantyl

    {
        echo "#!/usr/bin/env python3"
        cat _vantumMenuInit.py
    } > _vantumMenuInit.new && mv _vantumMenuInit.new vantyl-gen-menu
    python3 _vantumMenuInit.py /usr/share/applications
    install -D -m 644 menu.xml /root/.config/menu.xml
    install -D -m 755 vantyl-gen-menu /usr/local/bin/vantyl-gen-menu
}

