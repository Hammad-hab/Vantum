#!/bin/sh

# Wayland path unchanged - hsetroot is X11-only
if [ "$XDG_SESSION_TYPE" = "wayland" ]; then
	killall swaybg 2>/dev/null
	startswaybg &
	exit
fi

if [ "$1" = "-clear" ]; then
	hsetroot -solid '#000000'
	echo "[none]" > $HOME/.config/wallpaper/bg_img
	exit
fi

MODE="`cat $HOME/.config/wallpaper/backgroundmode 2>/dev/null`"
[ "$MODE" = "" ] && MODE="Scale"
[ "$MODE" = "Centred" ] && MODE="Centre"
[ "$MODE" = "Scaled" ] && MODE="Scale"

BGCOLOR='#000000'
case "$MODE" in
    Tile)
        hsetroot -tile "$1"
        ;;

    Centre)
        hsetroot -solid "$BGCOLOR" -center "$1"
        ;;

    Scale)
        # Preserve aspect ratio (letterbox)
        hsetroot -solid "$BGCOLOR" -full "$1"
        ;;

    Stretch)
        # Stretch image (distort)
        hsetroot -fill "$1"
        ;;

    Crop)
        # Preserve aspect ratio and crop (if supported)
        hsetroot -cover "$1"
        ;;

    *)
        hsetroot -solid "$BGCOLOR" -full "$1"
        ;;
esac