#!/bin/ash
# Vantum first-boot welcome

export TEXTDOMAIN=welcome1stboot
export OUTPUT_CHARSET=UTF-8

. /etc/DISTRO_SPECS
W_MSG="$(gettext "Welcome to ${DISTRO_NAME}.
Your system is ready to go — here's a quick look at what's available.")"

if check_internet ; then
	LABEL_INTERNET="$(gettext "You're connected. Manage your network anytime from the tray icon — left-click for status, right-click for options.")"
elif check_internet working_network ; then
	LABEL_INTERNET="$(gettext "A network interface is active, but you're not online yet. Use the button on the right to set up your connection.")"
else
	LABEL_INTERNET="$(gettext "Not connected yet. Click the button on the right to choose how you'd like to connect — it only takes a moment.")"
fi

LABEL_INTERNET="$(gettext "<b>Network</b>
${LABEL_INTERNET}")"
LABEL_NEEDHELP="$(gettext "<b>Need a hand?</b>
Open the Menu in the bottom-left corner for documentation and release notes. Once you're online, the browser home page has more resources.")"
LABEL_SETUP="$(gettext '<b>System Setup</b>
Configure your display driver, region, printer, sound, or input devices from the Setup panel, accessible from the top of the screen at any time.')"

export WELCOME_DIALOG='
<window title="'$(gettext 'Welcome to Vantum')'" icon-name="gtk-info" resizable="false">
<vbox>
	<hbox border-width="7" space-expand="true" space-fill="true">
      <text use-markup="true"><label>"<big>'"${W_MSG}"'</big>"</label></text>
    </hbox>
    <hbox border-width="7" space-expand="true" space-fill="true">
      <text space-expand="false" space-fill="false"><label>""</label></text>
      <text xalign="0" use-markup="true" space-expand="true" space-fill="true"><label>"'"${LABEL_INTERNET}"'"</label></text>
      <vbox space-expand="false" space-fill="false">
        <button>
          '$(/usr/lib/gtkdialog/xml_button-icon /usr/local/lib/X11/pixmaps/connect48.png huge)'
          <action>/usr/sbin/connectwizard & </action>
        </button>
      </vbox>
    </hbox>
    <hseparator></hseparator>
    <hbox border-width="7" space-expand="true" space-fill="true">
      <text space-expand="false" space-fill="false"><label>""</label></text>
      <text xalign="0" use-markup="true" space-expand="true" space-fill="true"><label>"'"${LABEL_SETUP}"'"</label></text>
      <vbox space-expand="false" space-fill="false">
        <button>
         '$(/usr/lib/gtkdialog/xml_button-icon /usr/local/lib/X11/pixmaps/configuration48.png huge)'
         <action>/usr/sbin/wizardwizard & </action>
        </button>
      </vbox>
    </hbox>
    <hseparator></hseparator>

    <hbox border-width="7" space-expand="true" space-fill="true">
      <text space-expand="false" space-fill="false"><label>""</label></text>
      <text xalign="0" use-markup="true" space-expand="true" space-fill="true"><label>"'"${LABEL_NEEDHELP}"'"</label></text>
      <vbox space-expand="false" space-fill="false">
        <text space-expand="false" space-fill="false"><label>""</label></text>
        <button>
         '$(/usr/lib/gtkdialog/xml_button-icon help.svg huge)'
         <action>basichtmlviewer file:///usr/share/doc/index.html & </action>
        </button>
      </vbox>
    </hbox>
    <hbox border-width="7" space-expand="true" space-fill="true">
      <pixmap><input file>/usr/share/doc/tray.png</input></pixmap>
      <text xalign="0" use-markup="true" space-expand="true" space-fill="true"><label>"'$(gettext "Tip: hover and click the tray applets to explore system tools.")'"</label></text>
    </hbox>
  </vbox>
</window>'

gtkdialog --center -p WELCOME_DIALOG 2>/dev/null

### END ###
