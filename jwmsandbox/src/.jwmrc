<JWM>

    <Desktops width="2" height="1"/>

    <WindowStyle decorations="flat">

        <Font>Inter SemiBold-12</Font>

        <Width>1</Width>
        <Height>30</Height>
        <Foreground>#ffffff</Foreground>

        <Background>#18181b</Background>

        <Outline>#2a2a2a</Outline>

        <Opacity>1.0</Opacity>

        <Active>
            <Foreground>#ffffff</Foreground>
            <Background>#27272a</Background>
            <Outline>#3f3f46</Outline>
        </Active>

    </WindowStyle>

     <TrayStyle>
        <Background>#18181b</Background>
        <Foreground>#ffffff</Foreground>
        <Outline>#2a2a2a</Outline>
        <Font>Inter SemiBold-11</Font>
    </TrayStyle>

    <TaskListStyle>
        <Active>
            <Foreground>#ffffff</Foreground>
            <Background>#2a2a2f</Background>
            <Outline>#35353c</Outline>
        </Active>
    </TaskListStyle>

    <ClockStyle>
        <Font>Inter SemiBold-16</Font>
        <Foreground>#ffffff</Foreground>
    </ClockStyle>

    <Tray x="0" y="-24" height="32" width="800" halign="center">
       <Spacer width="20"/>
            <TaskList labels="0"/>
        <Spacer width="20"/>
            <Clock/>
        <Spacer width="20"/>
    </Tray>


    <Key mask="A" key="F4">close</Key>

</JWM>